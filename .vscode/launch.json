{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "java",
            "name": "Run Zhonyal",
            "request": "launch",
            "mainClass": "Main",
            "classPaths": ["${workspaceFolder}/out", "${workspaceFolder}/lib/*"],
            "preLaunchTask": "compile-zhonyal",
            "vmArgs": [
                "-Dawt.useSystemAAFontSettings=lcd_hrgb",
                "-Dswing.aatext=true"
            ],
            "env": {
                "GDK_BACKEND": "x11"
            }
        }
    ]
}
